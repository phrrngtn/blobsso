# name: test/sql/blobsso.test
# description: blobsso 'sso' s3 secret provider — registration + input validation
# group: [sql]
#
# This covers the deterministic, network-free path: the provider is registered
# against the s3 secret type and validates its inputs. The positive path (a real
# AssumeRoleWithWebIdentity round-trip) is exercised by test/mock_sts_test.py
# (mock STS) and against live MinIO — neither fits a pure sqllogictest.

# Pull the prebuilt, signed httpfs at test time — it registers the s3 secret type
# our 'sso' provider attaches to. We do NOT compile httpfs into this build.
statement ok
INSTALL httpfs;

statement ok
LOAD httpfs;

require blobsso

# Missing sts_endpoint is rejected.
statement error
CREATE SECRET no_endpoint (TYPE s3, PROVIDER sso, token 'h.e.s');
----
sts_endpoint

# With an sts_endpoint but no token (and no token file / env), creation fails
# before any network call with a clear message.
statement error
CREATE SECRET no_token (TYPE s3, PROVIDER sso, sts_endpoint 'http://127.0.0.1:1/');
----
web-identity token
